## 데모 런타임의 포트/사용자/보안 토큰 기본값을 통합 관리하는 템플릿입니다.
POSTGRES_DB=stockrush
POSTGRES_USER=stockrush
POSTGRES_PASSWORD=stockrush
DEMO_ENV_REV=2026-06-17-gateway-boundary-v1

# Demo host ports intentionally differ from infra/local and host dev services.
# Edit these values when another local process already uses the default.
POSTGRES_HOST_PORT=25432
REDIS_HOST_PORT=26379
KAFKA_HOST_PORT=29092
KAFKA_UI_PORT=29090
KEYCLOAK_HOST_PORT=28088
GATEWAY_HOST_PORT=28080
CUSTOMER_APP_HOST_PORT=15173
ADMIN_APP_HOST_PORT=15174

# Demo Keycloak admin credentials (for runtime bootstrap and smoke token retrieval).
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Demo Keycloak OAuth client for smoke tokens.
KEYCLOAK_SMOKE_CLIENT_ID=stockrush-demo-smoke

# Demo users defined in infra/demo/keycloak/stockrush-realm.json.
KEYCLOAK_SMOKE_CUSTOMER_USERNAME=customer.demo@stockrush.local
KEYCLOAK_SMOKE_CUSTOMER_PASSWORD=demo-customer-pass
KEYCLOAK_SMOKE_ADMIN_USERNAME=admin.demo@stockrush.local
KEYCLOAK_SMOKE_ADMIN_PASSWORD=demo-admin-pass

# GHCR image deployment defaults used by scripts/deploy-local.
STOCKRUSH_IMAGE_REGISTRY=ghcr.io
STOCKRUSH_IMAGE_OWNER=cyson21
STOCKRUSH_IMAGE_TAG=latest-demo
